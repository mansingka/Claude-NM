    <h3>Returns &amp; balance sheet</h3>
    <table>
      <thead><tr><th>Metric</th><th>FY23</th><th>FY24</th><th>FY25</th><th>FY26</th></tr></thead>
      <tbody>
        <tr><td>ROE %</td><td>16%</td><td>16%</td><td>~14–16%</td><td>~13%</td></tr>
        <tr><td>ROCE %</td><td>19%</td><td>16%</td><td>~19%</td><td>~18–19%</td></tr>
        <tr><td>Total borrowings (₹ cr)</td><td>86</td><td>97</td><td>104</td><td>~130</td></tr>
