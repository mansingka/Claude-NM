<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tic Tac Toe</title>
<style>
  :root {
    --bg: #0f172a;
    --panel: #1e293b;
    --line: #334155;
    --x: #38bdf8;
    --o: #f472b6;
    --text: #e2e8f0;
    --accent: #facc15;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
    background: radial-gradient(circle at top, #1e293b, var(--bg));
    color: var(--text);
    padding: 20px;
  }
  h1 { margin: 0 0 4px; font-weight: 700; letter-spacing: 1px; }
  .status {
    font-size: 1.2rem;
    min-height: 1.6em;
    margin: 12px 0 18px;
    font-weight: 600;
  }
  .board {
    display: grid;
    grid-template-columns: repeat(3, 96px);
    grid-template-rows: repeat(3, 96px);
    gap: 8px;
    background: var(--line);
    padding: 8px;
    border-radius: 14px;
  }
  .cell {
    background: var(--panel);
    border: none;
    border-radius: 8px;
    font-size: 3rem;
    font-weight: 800;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    transition: background .15s, transform .05s;
  }
  .cell:hover:not(:disabled) { background: #2c3e57; }
  .cell:active:not(:disabled) { transform: scale(.95); }
  .cell:disabled { cursor: default; }
  .cell.x { color: var(--x); }
  .cell.o { color: var(--o); }
  .cell.win { background: var(--accent); color: #0f172a; }
  .controls { margin-top: 22px; display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
  button.btn {
    background: var(--panel);
    color: var(--text);
    border: 1px solid var(--line);
    padding: 10px 16px;
    border-radius: 8px;
    font-size: .95rem;
    cursor: pointer;
    transition: background .15s;
  }
  button.btn:hover { background: #2c3e57; }
  button.btn.active { background: var(--x); color: #0f172a; border-color: var(--x); }
  .scoreboard {
    display: flex;
    gap: 24px;
    margin-top: 22px;
    font-size: .95rem;
  }
  .scoreboard span { font-weight: 700; }
  .label { opacity: .7; font-size: .85rem; margin-right: 16px; align-self: center; }
</style>
</head>
<body>
  <h1>Tic&nbsp;Tac&nbsp;Toe</h1>
  <div class="status" id="status">Your turn (X)</div>

  <div class="board" id="board"></div>

  <div class="controls">
    <span class="label">Mode:</span>
    <button class="btn active" id="mode-ai" data-mode="ai">vs Computer</button>
    <button class="btn" id="mode-2p" data-mode="2p">2 Players</button>
    <button class="btn" id="reset">New Game</button>
  </div>

  <div class="scoreboard">
    <div>X wins: <span id="score-x">0</span></div>
    <div>O wins: <span id="score-o">0</span></div>
    <div>Draws: <span id="score-d">0</span></div>
  </div>

<script>
  const boardEl = document.getElementById('board');
  const statusEl = document.getElementById('status');
  const WINS = [
    [0,1,2],[3,4,5],[6,7,8], // rows
    [0,3,6],[1,4,7],[2,5,8], // cols
    [0,4,8],[2,4,6]          // diagonals
  ];

  let board, current, gameOver, mode = 'ai';
  const score = { X: 0, O: 0, D: 0 };

  function init() {
    board = Array(9).fill('');
    current = 'X';
    gameOver = false;
    boardEl.innerHTML = '';
    for (let i = 0; i < 9; i++) {
      const btn = document.createElement('button');
      btn.className = 'cell';
      btn.dataset.idx = i;
      btn.addEventListener('click', onCellClick);
      boardEl.appendChild(btn);
    }
    setStatus();
  }

  function setStatus() {
    if (mode === 'ai') {
      statusEl.textContent = current === 'X' ? 'Your turn (X)' : 'Computer thinking…';
    } else {
      statusEl.textContent = `Player ${current}'s turn`;
    }
  }

  function onCellClick(e) {
    const i = +e.currentTarget.dataset.idx;
    if (gameOver || board[i]) return;
    if (mode === 'ai' && current !== 'X') return; // only human plays X
    move(i);
    if (!gameOver && mode === 'ai' && current === 'O') {
      setStatus();
      setTimeout(aiMove, 350);
    }
  }

  function move(i) {
    board[i] = current;
    const cell = boardEl.children[i];
    cell.textContent = current;
    cell.classList.add(current.toLowerCase());
    cell.disabled = true;

    const result = checkWinner(board);
    if (result) {
      endGame(result);
      return;
    }
    current = current === 'X' ? 'O' : 'X';
    setStatus();
  }

  function endGame(result) {
    gameOver = true;
    if (result.winner === 'draw') {
      score.D++;
      statusEl.textContent = "It's a draw!";
    } else {
      score[result.winner]++;
      statusEl.textContent = `${result.winner} wins!`;
      result.line.forEach(idx => boardEl.children[idx].classList.add('win'));
    }
    [...boardEl.children].forEach(c => c.disabled = true);
    updateScore();
  }

  function updateScore() {
    document.getElementById('score-x').textContent = score.X;
    document.getElementById('score-o').textContent = score.O;
    document.getElementById('score-d').textContent = score.D;
  }

  function checkWinner(b) {
    for (const line of WINS) {
      const [a, c, d] = line;
      if (b[a] && b[a] === b[c] && b[a] === b[d]) {
        return { winner: b[a], line };
      }
    }
    if (b.every(v => v)) return { winner: 'draw', line: [] };
    return null;
  }

  // Unbeatable AI via minimax
  function aiMove() {
    if (gameOver) return;
    const best = minimax(board, 'O');
    move(best.index);
  }

  function minimax(b, player) {
    const result = checkWinner(b);
    if (result) {
      if (result.winner === 'O') return { score: 10 };
      if (result.winner === 'X') return { score: -10 };
      return { score: 0 };
    }
    const moves = [];
    for (let i = 0; i < 9; i++) {
      if (!b[i]) {
        b[i] = player;
        const next = minimax(b, player === 'O' ? 'X' : 'O');
        moves.push({ index: i, score: next.score });
        b[i] = '';
      }
    }
    if (player === 'O') {
      return moves.reduce((best, m) => m.score > best.score ? m : best);
    } else {
      return moves.reduce((best, m) => m.score < best.score ? m : best);
    }
  }

  // Controls
  document.getElementById('reset').addEventListener('click', init);
  document.getElementById('mode-ai').addEventListener('click', () => setMode('ai'));
  document.getElementById('mode-2p').addEventListener('click', () => setMode('2p'));

  function setMode(m) {
    mode = m;
    document.getElementById('mode-ai').classList.toggle('active', m === 'ai');
    document.getElementById('mode-2p').classList.toggle('active', m === '2p');
    init();
  }

  init();
</script>
</body>
</html>
